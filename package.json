{
  "name": "pi-agent-router",
  "version": "0.8.1",
  "description": "Pi extension for active-agent routing, controlled subagent delegation, and task result rendering.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "!src/test",
    "!src/test.ts",
    "config/config.example.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run typecheck",
    "lint": "npm run --silent typecheck && node ./scripts/extension-standards-guard.mjs",
    "typecheck": "npx --yes -p typescript@5.7.3 tsc -p tsconfig.json",
    "test": "npx --yes tsx@4.22.3 ./src/test/run-tests.ts",
    "check": "npm run build && npm run lint && npm run test"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "pi-tui",
    "coding-agent",
    "agent-routing",
    "active-agent",
    "delegation",
    "subagents",
    "task-routing",
    "parallel-delegation"
  ],
  "author": "MasuRii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MasuRii/pi-agent-router.git"
  },
  "bugs": {
    "url": "https://github.com/MasuRii/pi-agent-router/issues"
  },
  "homepage": "https://github.com/MasuRii/pi-agent-router#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "typebox": "^1.2.14",
    "@earendil-works/pi-ai": "^0.74.0 || ^0.75.0 || ^0.77.0 || ^0.78.0 || ^0.79.0",
    "@earendil-works/pi-coding-agent": "^0.74.0 || ^0.75.0 || ^0.77.0 || ^0.78.0 || ^0.79.0",
    "@earendil-works/pi-tui": "^0.74.0 || ^0.75.0 || ^0.77.0 || ^0.78.0 || ^0.79.0"
  },
  "overrides": {
    "fast-xml-builder": "1.1.7",
    "ip-address": "10.1.1"
  }
}
